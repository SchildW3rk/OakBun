{
  "name": "@oakbun/jwt",
  "version": "4.0.1",
  "description": "JWT plugin for the OakBun framework.",
  "author": "René (SchildW3rk)",
  "license": "MIT",
  "homepage": "https://github.com/SchildW3rk/OakBun#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SchildW3rk/OakBun"
  },
  "keywords": [
    "bun",
    "jwt",
    "typescript",
    "backend",
    "oakbun"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "jose": "^6.2.2"
  },
  "peerDependencies": {
    "oakbun": ">=0.5.4"
  },
  "devDependencies": {
    "oakbun": "workspace:*"
  },
  "bugs": {
    "url": "https://github.com/SchildW3rk/OakBun/issues"
  }
}
