{
  "name": "@oakbun/logger",
  "version": "1.0.0",
  "description": "Structured logger plugin for the OakBun framework.",
  "author": "René (SchildW3rk)",
  "license": "MIT",
  "homepage": "https://github.com/SchildW3rk/OakBun#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SchildW3rk/OakBun"
  },
  "keywords": [
    "bun",
    "logger",
    "logging",
    "typescript",
    "backend",
    "oakbun"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build && bunx tsc --noEmit"
  },
  "peerDependencies": {
    "oakbun": ">=0.2.1"
  },
  "devDependencies": {
    "oakbun": "workspace:*",
    "bun-types": "latest"
  },
  "bugs": {
    "url": "https://github.com/SchildW3rk/OakBun/issues"
  }
}
