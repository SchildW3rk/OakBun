{
  "name": "veln-workspace",
  "private": true,
  "workspaces": ["packages/*", "examples/*"],
  "scripts": {
    "build": "bun run --filter 'oakbun' build && bun run --filter './packages/*' build",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "better-auth": "^1.5.5",
    "jose": "^6.2.2"
  }
}
